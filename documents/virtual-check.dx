<svg viewBox="0 0 900 230" role="img" aria-label="Virtual document hydration flow">
	<rect width="900" height="230" fill="#0a1122"/>
	<g font-family="monospace" font-size="13" fill="#eef7ff">
		<rect x="40" y="80" width="180" height="54" rx="9" fill="#2a7fda"/><text x="75" y="112">docdb:/ path</text>
		<rect x="290" y="80" width="220" height="54" rx="9" fill="#2a68c2"/><text x="325" y="112">doc-service lookup</text>
		<rect x="580" y="80" width="260" height="54" rx="9" fill="#18998a"/><text x="626" y="112">render + capture surface</text>
