		<rect x="120" y="96" width="469" height="24" fill="#4de0be"/><text x="605" y="114">B 46.94%</text>
		<rect x="120" y="132" width="472" height="24" fill="#4de0be"/><text x="605" y="150">C 47.22%</text>
	</g>
</svg>
