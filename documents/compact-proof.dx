::heading level=1 id=compact-proof
Compaction Proof
::end

::paragraph id=compact-proof-method
For each sample, reduction_bytes = md_bytes - packed_bytes and reduction_pct = reduction_bytes / md_bytes * 100.
::end

::code id=compact-proof-metrics language=json
[
	{"sample":"A","md_bytes":1200,"packed_bytes":630,"reduction_bytes":570,"reduction_pct":47.50},
	{"sample":"B","md_bytes":980,"packed_bytes":520,"reduction_bytes":460,"reduction_pct":46.94},
	{"sample":"C","md_bytes":1440,"packed_bytes":760,"reduction_bytes":680,"reduction_pct":47.22}
]
::end

::code id=compact-proof-table language=html
<table>
	<thead><tr><th>Sample</th><th>MD (B)</th><th>Packed (B)</th><th>Reduction (B)</th><th>Reduction (%)</th></tr></thead>
