{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmitOnError": false,
    "declaration": false,
    "allowJs": false,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "lib": ["ES2022", "DOM"],
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "vscode-extension/media/**/*.ts"
  ],
  "exclude": [
    "build/**",
    "coverage/**",
    "data/**",
    "node_modules/**",
    "test/**"
  ]
}