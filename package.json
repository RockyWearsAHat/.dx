{
  "name": "doc-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:native": "node-gyp rebuild || node -e \"console.warn('Native SQLite bridge build failed; falling back to node:sqlite.')\"",
    "mcp": "npm run build:native && node src/mcp-server.js",
    "mcp:dev": "npm run build:native && node --watch src/mcp-server.js",
    "verify:doc-fsm": "node scripts/verify-doc-save-fsm.mjs",
    "test": "node --test test/**/*.test.mjs",
    "test:coverage": "c8 --all --reporter=text --reporter=lcov --100 --include=src/database.js --include=src/doc-service.js --include=src/doc-format.js --include=src/doc-binary.js --include=src/doc-view.js --include=src/view-state.js --include=src/global-db-path.js --include=src/sqlite-native.js --include=vscode-extension/media/doc-pipeline.js node --test test/**/*.test.mjs",
    "setup": "node src/cli.js setup",
    "ingest": "node src/cli.js ingest",
    "reconstruct": "node src/cli.js reconstruct",
    "upgrade:install": "node scripts/upgrade-install.mjs"
  },
  "dependencies": {
    "node-addon-api": "^8.3.1",
    "playwright": "^1.60.0"
  },
  "devDependencies": {
    "c8": "^10.1.3",
    "node-gyp": "^11.2.0"
  },
  "engines": {
    "node": ">=23"
  }
}
